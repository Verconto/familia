+async def cmd_approve(ctx: CommandContext) -> OutboundMessage:
+    """Approve a pending policy-gated action by token (familia extension)."""
+    msg = ctx.msg
+    raw = ctx.args.strip() if ctx.args else ctx.raw.removeprefix("/approve").strip()
+    token = raw.split()[0] if raw else ""
+
+    def reply(text: str) -> OutboundMessage:
+        return OutboundMessage(
+            channel=msg.channel,
+            chat_id=msg.chat_id,
+            content=text,
+            metadata=dict(msg.metadata or {}),
+        )
+
+    if not token:
+        return reply("Usage: /approve <token>")
+
+    store = get_pending_store()
+    pending = store.peek(token)
+    if pending is None:
+        audit.log_event(
+            "policy_expired", token=token, attempted_by=msg.actor, verb="approve"
+        )
+        return reply(f"No pending action for token {token} (expired or unknown).")
+
+    if not pending.allows_approver(msg.actor):
+        approvers = ", ".join(pending.approvers) if pending.approvers else "no one"
+        audit.log_event(
+            "policy_approve_denied",
+            token=token,
+            attempted_by=msg.actor,
+            approvers=list(pending.approvers),
+        )
+        return reply(
+            f"You are not authorized to approve this action. "
+            f"Required approver(s): {approvers}."
+        )
+
+    # Commit: remove from store and execute through the message tool.
+    taken = store.take(token)
+    if taken is None:
+        audit.log_event(
+            "policy_expired", token=token, attempted_by=msg.actor, verb="approve"
+        )
+        return reply(f"Pending action {token} just expired.")
+
+    tool = None
+    if ctx.loop is not None:
+        tool = ctx.loop.tools.get("message") if hasattr(ctx.loop, "tools") else None
+    if not isinstance(tool, MessageTool):
+        return reply("Message tool is unavailable; cannot execute the approved action.")
+
+    try:
+        await tool.send_approved(taken.outbound)
+    except Exception as exc:
+        audit.log_event(
+            "policy_approve_failed",
+            token=token,
+            approver=msg.actor,
+            action=taken.action,
+            target_channel=taken.outbound.channel,
+            target_chat_id=taken.outbound.chat_id,
+            requester_actor=taken.requester_actor,
+            error=str(exc),
+        )
+        return reply(f"Approved action failed to send: {exc}")
+
+    audit.log_event(
+        "policy_approve",
+        token=token,
+        approver=msg.actor,
+        action=taken.action,
+        target_channel=taken.outbound.channel,
+        target_chat_id=taken.outbound.chat_id,
+        requester_actor=taken.requester_actor,
+        via="slash_command",
+    )
+    return reply(
+        f"Approved {taken.action} to {taken.outbound.channel}:{taken.outbound.chat_id}."
+    )
+
+
