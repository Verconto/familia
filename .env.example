# Secrets and runtime env-overrides for familia + nanobot.
# Copy to ".env" (never commit) and fill in real values.

# --- Channel tokens (required if you enable the channel in config.json) ---
TELEGRAM_TOKEN=
VK_GROUP_TOKEN=

# --- LLM provider keys (set whichever your config.json.providers references) ---
# See nanobot/docs/configuration.md for the full provider list.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# OPENROUTER_API_KEY=

# --- familia wiring ---
# Principal id of the owner (routing target for system/cron messages).
FAMILIA_OWNER_ACTOR=owner

# Single global timezone (IANA name) for all participants. Controls how
# datetimes are shown to users and how user-provided times (reminders,
# schedules) are interpreted. Storage is always UTC regardless. Only
# admins can change it at runtime via the admin_set_tz tool, which
# writes to FAMILIA_TZ_STATE_FILE; this env var is the bootstrap
# default used when that file is absent.
FAMILIA_TZ=UTC

# Dream consolidator memX key. Used by the dream_memory_set tool to write
# cross-scope summaries on behalf of the "dream_consolidator" actor. Must
# match an entry in memx-config/acl.json with write access to shared:*,
# private:*, and pair:* keys. Fallback "local_dev_key" works only for the
# single-key dev ACL shipped with memX upstream.
# DREAM_CONSOLIDATOR_MEMX_KEY=

# memX endpoint. Default (http://172.17.0.1:8100) ожидает, что memX поднят
# на том же хосте через docker-compose.memx.yml (bind на docker bridge
# gateway). Для memX на другом хосте — укажи публичный URL.
# MEMX_BASE_URL=http://172.17.0.1:8100

# VK CDN throttles large photos from non-RU IPs. Route media fetches through
# a socks5/http proxy if VK attachments arrive as 0-byte or time out.
# Accepts socks5://host:port or http://host:port.
# VK_MEDIA_PROXY=socks5://127.0.0.1:1080

# --- deploy.sh / run_tests.sh (VM mode) ---
# FAMILIA_VM=user@host
# REMOTE_ROOT=/opt/familia/upstream
